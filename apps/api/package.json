{
  "name": "@mapnova/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply mapnova --local",
    "db:migrate:remote": "wrangler d1 migrations apply mapnova --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@mapnova/shared": "workspace:*",
    "@sentry/cloudflare": "^8.37.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
